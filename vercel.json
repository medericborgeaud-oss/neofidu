{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/zefix-backfill?canton=VD",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/zefix-backfill?canton=GE",
      "schedule": "0 5 * * 2"
    },
    {
      "path": "/api/cron/zefix-backfill?canton=VS",
      "schedule": "0 5 * * 3"
    },
    {
      "path": "/api/cron/zefix-backfill?canton=FR",
      "schedule": "0 5 * * 4"
    },
    {
      "path": "/api/cron/zefix-backfill?canton=NE",
      "schedule": "0 5 * * 5"
    },
    {
      "path": "/api/cron/zefix-backfill?canton=JU",
      "schedule": "0 5 * * 6"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/guide",
      "destination": "/guide/deductions-fiscales",
      "permanent": true
    }
  ]
}
